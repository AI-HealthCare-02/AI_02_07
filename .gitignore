# ──────────────────────────────────────────────
# AI_02_07 루트 .gitignore
# 각 폴더별 세부 설정은 backend/.gitignore, frontend/.gitignore 참고
# ──────────────────────────────────────────────

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Python 공통 ──
__pycache__/
*.py[cod]
*$py.class
.venv/
.python-version

# ── 테스트 ──
.pytest_cache/
htmlcov/
.coverage

# ── 빌드 ──
dist/
build/
*.egg-info/

# ── 로그 ──
*.log
logs/
