# Dockerfile.worker
# ──────────────────────────────────────────────
# AI Worker 이미지
# OpenAI API + Clova OCR 기반 (GPU 불필요)
# ──────────────────────────────────────────────

# ── Stage 1: 의존성 설치 ──
FROM python:3.13-slim AS builder

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /code

COPY pyproject.toml uv.lock ./
RUN UV_PROJECT_ENVIRONMENT=/code/.venv uv sync --group ai --no-dev --frozen --no-cache

# ── Stage 2: 런타임 이미지 ──
FROM python:3.13-slim AS runtime

WORKDIR /code

COPY --from=builder /code/.venv /code/.venv
COPY ai_worker/ /code/ai_worker/

ENV PATH="/code/.venv/bin:$PATH"
ENV PYTHONPATH="/code"

CMD ["python", "-m", "ai_worker.main"]
